{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://proyecto-imagenes-ia/contracts/images.age_estimated.v1.schema.json",
  "title": "images.age_estimated v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event",
    "payload"
  ],
  "properties": {
    "event": {
      "allOf": [
        {
          "$ref": "./_defs.schema.json#/$defs/eventMetadata"
        },
        {
          "type": "object",
          "properties": {
            "event_type": {
              "const": "images.age_estimated"
            }
          }
        }
      ]
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bucket",
        "object_key",
        "faces"
      ],
      "properties": {
        "bucket": {
          "type": "string",
          "minLength": 1
        },
        "object_key": {
          "type": "string",
          "minLength": 1
        },
        "faces": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "face_id",
              "bbox",
              "estimated_age",
              "is_minor"
            ],
            "properties": {
              "face_id": {
                "type": "string",
                "minLength": 1
              },
              "bbox": {
                "$ref": "./_defs.schema.json#/$defs/boundingBox"
              },
              "estimated_age": {
                "type": "integer",
                "minimum": 0,
                "maximum": 120
              },
              "is_minor": {
                "type": "boolean"
              },
              "confidence": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            }
          }
        }
      }
    }
  }
}
