{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://proyecto-imagenes-ia/contracts/_defs.schema.json",
  "title": "Common Event Definitions",
  "type": "object",
  "$defs": {
    "uuid": {
      "type": "string",
      "format": "uuid"
    },
    "requestId": {
      "type": "string",
      "minLength": 1
    },
    "imageId": {
      "type": "string",
      "minLength": 1
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request_id",
        "image_id"
      ],
      "properties": {
        "request_id": {
          "$ref": "#/$defs/requestId"
        },
        "image_id": {
          "$ref": "#/$defs/imageId"
        },
        "correlation_id": {
          "$ref": "#/$defs/uuid"
        }
      }
    },
    "eventMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "event_type",
        "event_version",
        "occurred_at",
        "trace"
      ],
      "properties": {
        "event_id": {
          "$ref": "#/$defs/uuid"
        },
        "event_type": {
          "type": "string",
          "minLength": 1
        },
        "event_version": {
          "const": "v1"
        },
        "occurred_at": {
          "type": "string",
          "format": "date-time"
        },
        "trace": {
          "$ref": "#/$defs/trace"
        },
        "source": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "boundingBox": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x",
        "y",
        "width",
        "height"
      ],
      "properties": {
        "x": {
          "type": "integer",
          "minimum": 0
        },
        "y": {
          "type": "integer",
          "minimum": 0
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
