{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://proyecto-imagenes-ia/contracts/cmd.face_detection.v1.schema.json",
  "title": "cmd.face_detection v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event",
    "payload"
  ],
  "properties": {
    "event": {
      "allOf": [
        {
          "$ref": "./_defs.schema.json#/$defs/eventMetadata"
        },
        {
          "type": "object",
          "properties": {
            "event_type": {
              "const": "cmd.face_detection"
            }
          }
        }
      ]
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bucket",
        "object_key"
      ],
      "properties": {
        "bucket": {
          "type": "string",
          "minLength": 1
        },
        "object_key": {
          "type": "string",
          "minLength": 1
        },
        "priority": {
          "type": "string",
          "enum": [
            "low",
            "normal",
            "high"
          ]
        }
      }
    }
  }
}
