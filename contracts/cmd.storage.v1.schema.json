{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://proyecto-imagenes-ia/contracts/cmd.storage.v1.schema.json",
  "title": "cmd.storage v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event",
    "payload"
  ],
  "properties": {
    "event": {
      "allOf": [
        {
          "$ref": "./_defs.schema.json#/$defs/eventMetadata"
        },
        {
          "type": "object",
          "properties": {
            "event_type": {
              "const": "cmd.storage"
            }
          }
        }
      ]
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "output_bucket",
        "output_object_key",
        "status"
      ],
      "properties": {
        "output_bucket": {
          "type": "string",
          "minLength": 1
        },
        "output_object_key": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "COMPLETED",
            "FAILED"
          ]
        },
        "pixelated_faces_count": {
          "type": "integer",
          "minimum": 0
        },
        "total_faces_count": {
          "type": "integer",
          "minimum": 0
        },
        "error_message": {
          "type": "string"
        }
      }
    }
  }
}
