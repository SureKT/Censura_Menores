{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://proyecto-imagenes-ia/contracts/images.raw.v1.schema.json",
  "title": "images.raw v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event",
    "payload"
  ],
  "properties": {
    "event": {
      "allOf": [
        {
          "$ref": "./_defs.schema.json#/$defs/eventMetadata"
        },
        {
          "type": "object",
          "properties": {
            "event_type": {
              "const": "images.raw"
            }
          }
        }
      ]
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bucket",
        "object_key",
        "content_type",
        "size_bytes"
      ],
      "properties": {
        "bucket": {
          "type": "string",
          "minLength": 1
        },
        "object_key": {
          "type": "string",
          "minLength": 1
        },
        "content_type": {
          "type": "string",
          "pattern": "^image/"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "uploaded_by": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
